# 将以下内容追加到 ~/.bashrc 末尾，然后执行 source ~/.bashrc

# ============================================
# MiniMax API 配置 (Claude Code 兼容格式)
# ============================================
export ANTHROPIC_BASE_URL="https://api.minimaxi.com/anthropic"
export ANTHROPIC_AUTH_TOKEN="sk-your_api_key_here"
export API_TIMEOUT_MS="3000000"
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="1"

# 模型配置
export ANTHROPIC_MODEL="MiniMax-M2.5"
export ANTHROPIC_SMALL_FAST_MODEL="MiniMax-M2.5"
export ANTHROPIC_DEFAULT_SONNET_MODEL="MiniMax-M2.5"
export ANTHROPIC_DEFAULT_OPUS_MODEL="MiniMax-M2.5"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="MiniMax-M2.5"

# ============================================
# 交易相关配置
# ============================================
export TRADE_MODE="paper"
export INITIAL_CAPITAL="10000"
export MAX_POSITION_RATIO="0.3"
export STOP_LOSS_PCT="0.05"
export TAKE_PROFIT_PCT="0.10"
export MAX_DAILY_LOSS_PCT="0.02"

# 通知配置 (钉钉/飞书)
export DINGTALK_WEBHOOK="https://oapi.dingtalk.com/robot/send?access_token=your_token"
export FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/your_token"

# 数据路径
export TRADE_DATA_DIR="$HOME/trading_data"
export TRADE_LOG_DIR="$HOME/trading_logs"
